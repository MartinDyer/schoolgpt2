<html>
  <body>
    <meta charset="utf-8" />
    <h1>{{ school_name }} teacher safeguarding summary</h1>
    <p>Summary-only school safeguarding awareness. No raw student messages are included.</p>
    <ul>
      <li>Blocked/flagged searches: {{ summary.blocked_searches }}</li>
      <li>Medium or higher safeguarding incidents: {{ summary.medium_or_higher_incidents }}</li>
      <li>Referral required: {{ 'Yes' if summary.referral_required else 'No' }}</li>
    </ul>
    <h2>Recurring risk patterns</h2>
    <ul>
    {% for item in summary.recurring_risk_patterns %}
      <li>{{ item }}</li>
    {% endfor %}
    </ul>
    {% if summary.referral_required %}
    <p><strong>Action:</strong> Refer safeguarding concerns to the DSL for detailed review.</p>
    {% endif %}
  </body>
</html>

<html>
  <body>
    <meta charset="utf-8" />
    <h1>{{ school_name }} usage summary</h1>
    <p>Aggregate-only metrics. No raw student messages are included.</p>
    <ul>
    {% for summary in summaries %}
      <li>
        {{ summary.usage_date|localdate(school_timezone) }} — users: {{ summary.unique_users }},
        sessions: {{ summary.unique_sessions }},
        messages: {{ summary.total_messages }},
        total tokens: {{ summary.total_tokens or 0 }}
      </li>
    {% endfor %}
    </ul>
  </body>
</html>

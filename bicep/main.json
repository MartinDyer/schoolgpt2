{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "17480083884849357162"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "uksouth",
      "metadata": {
        "description": "Azure region for the resource group and all resources."
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "production",
      "metadata": {
        "description": "Environment name used in tags and generated names."
      }
    },
    "schoolName": {
      "type": "string",
      "defaultValue": "SchoolGPT",
      "metadata": {
        "description": "School name used in tags and generated names."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "schoolgpt",
      "metadata": {
        "description": "Optional short prefix used when generating names. Letters and numbers are safest."
      }
    },
    "azureTenantId": {
      "type": "string",
      "metadata": {
        "description": "Azure tenant ID used by Key Vault and optional SQL Entra admin configuration."
      }
    },
    "keyVaultAdminObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID that should receive Key Vault admin access."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the App Service plan name. Leave empty to generate."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the web app name. Leave empty to generate a globally unique name."
      }
    },
    "appInsightsName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the Application Insights name. Leave empty to generate."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the Log Analytics workspace name. Leave empty to generate."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the Key Vault name. Leave empty to generate a globally unique name."
      }
    },
    "sqlServerName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the SQL Server name. Leave empty to generate a globally unique name."
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "defaultValue": "schoolgptdb",
      "metadata": {
        "description": "SQL database name."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "sqladminuser",
      "metadata": {
        "description": "SQL administrator username."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional SQL administrator password. Leave empty to auto-generate."
      }
    },
    "sqlSkuName": {
      "type": "string",
      "defaultValue": "S1",
      "metadata": {
        "description": "SQL database SKU, for example Basic, S0, or S1."
      }
    },
    "appServiceSku": {
      "type": "string",
      "defaultValue": "B2",
      "metadata": {
        "description": "App Service plan SKU, for example B1, B2, S1, or P1v3."
      }
    },
    "deployAiFoundry": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy Azure AI Foundry resources in the same deployment."
      }
    },
    "aiFoundryName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override for the AI Foundry account name. Leave empty to generate a globally unique name."
      }
    },
    "aiFoundryCustomSubdomain": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom subdomain for AI Foundry. Leave empty to derive from the AI Foundry name."
      }
    },
    "aiDeploymentName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Model deployment name exposed to the app."
      }
    },
    "aiModelName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Azure OpenAI model name to deploy."
      }
    },
    "aiModelVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "metadata": {
        "description": "Azure OpenAI model version to deploy."
      }
    },
    "aiDeploymentSkuName": {
      "type": "string",
      "defaultValue": "GlobalStandard",
      "metadata": {
        "description": "Deployment SKU for the Azure OpenAI model deployment."
      }
    },
    "aiDeploymentCapacity": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Capacity for the Azure OpenAI deployment."
      }
    },
    "raiPolicyName": {
      "type": "string",
      "defaultValue": "schoolgpt-default-rai",
      "metadata": {
        "description": "Optional RAI policy name. Leave empty to skip custom RAI policy creation."
      }
    },
    "azureOpenAiApiVersion": {
      "type": "string",
      "defaultValue": "2025-01-01-preview",
      "metadata": {
        "description": "API version exposed to the Node app."
      }
    },
    "autoGrantAiAccess": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create the OpenAI user role assignment for the web app managed identity automatically."
      }
    },
    "existingAiFoundryEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional endpoint for an existing AI Foundry resource. Required when deployAiFoundry is false."
      }
    },
    "existingAiFoundryResourceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional resource name for an existing AI Foundry resource. Required when deployAiFoundry is false and autoGrantAiAccess is true."
      }
    },
    "sqlAzureAdAdminLogin": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional SQL Entra admin login UPN."
      }
    },
    "sqlAzureAdAdminObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional SQL Entra admin object ID."
      }
    }
  },
  "variables": {
    "normalizedPrefix": "[toLower(replace(replace(replace(parameters('namePrefix'), ' ', ''), '-', ''), '_', ''))]",
    "safePrefix": "[if(empty(variables('normalizedPrefix')), 'schoolgpt', variables('normalizedPrefix'))]",
    "uniqueSuffix": "[toLower(uniqueString(subscription().id, resourceGroup().id))]",
    "compactPrefix": "[take(format('{0}{1}', variables('safePrefix'), variables('uniqueSuffix')), 18)]",
    "generatedAppServicePlanName": "[if(empty(parameters('appServicePlanName')), format('{0}-asp', take(variables('safePrefix'), 20)), parameters('appServicePlanName'))]",
    "generatedWebAppName": "[if(empty(parameters('webAppName')), take(format('{0}app', variables('compactPrefix')), 60), parameters('webAppName'))]",
    "generatedAppInsightsName": "[if(empty(parameters('appInsightsName')), format('{0}-appi', take(variables('safePrefix'), 18)), parameters('appInsightsName'))]",
    "generatedLogAnalyticsWorkspaceName": "[if(empty(parameters('logAnalyticsWorkspaceName')), format('{0}-log', take(variables('safePrefix'), 18)), parameters('logAnalyticsWorkspaceName'))]",
    "generatedKeyVaultName": "[if(empty(parameters('keyVaultName')), take(format('{0}kv', variables('compactPrefix')), 24), parameters('keyVaultName'))]",
    "generatedSqlServerName": "[if(empty(parameters('sqlServerName')), take(format('{0}sql', variables('compactPrefix')), 63), parameters('sqlServerName'))]",
    "generatedAiFoundryName": "[if(empty(parameters('aiFoundryName')), take(format('{0}ai', variables('compactPrefix')), 64), parameters('aiFoundryName'))]",
    "effectiveAiCustomSubdomain": "[if(empty(parameters('aiFoundryCustomSubdomain')), variables('generatedAiFoundryName'), parameters('aiFoundryCustomSubdomain'))]",
    "sqlPassword": "[if(empty(parameters('sqlAdminPassword')), format('Sql!{0}Aa1', take(uniqueString(subscription().id, resourceGroup().id, variables('generatedSqlServerName'), parameters('sqlDatabaseName')), 16)), parameters('sqlAdminPassword'))]",
    "effectiveAiFoundryName": "[if(parameters('deployAiFoundry'), variables('generatedAiFoundryName'), parameters('existingAiFoundryResourceName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('generatedLogAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 90
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "Centralized Logging",
        "ManagedBy": "Bicep"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('generatedAppInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('generatedLogAnalyticsWorkspaceName'))]",
        "RetentionInDays": 90
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "Application Monitoring",
        "ManagedBy": "Bicep"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('generatedLogAnalyticsWorkspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('generatedKeyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "tenantId": "[parameters('azureTenantId')]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enabledForDeployment": false,
        "enabledForTemplateDeployment": true,
        "enabledForDiskEncryption": false,
        "enableRbacAuthorization": false,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7,
        "accessPolicies": [
          {
            "tenantId": "[parameters('azureTenantId')]",
            "objectId": "[parameters('keyVaultAdminObjectId')]",
            "permissions": {
              "secrets": [
                "get",
                "set",
                "list",
                "delete",
                "backup",
                "restore",
                "purge"
              ],
              "keys": [
                "get",
                "list",
                "create",
                "delete",
                "update",
                "purge"
              ]
            }
          }
        ],
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "Secure Configuration Storage",
        "ManagedBy": "Bicep"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('generatedAppServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServiceSku')]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "App Hosting",
        "ManagedBy": "Bicep"
      }
    },
    {
      "condition": "[parameters('deployAiFoundry')]",
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('generatedAiFoundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "customSubDomainName": "[variables('effectiveAiCustomSubdomain')]",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "Azure AI Foundry",
        "ManagedBy": "Bicep"
      }
    },
    {
      "condition": "[and(parameters('deployAiFoundry'), not(empty(parameters('raiPolicyName'))))]",
      "type": "Microsoft.CognitiveServices/accounts/raiPolicies",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('generatedAiFoundryName'), parameters('raiPolicyName'))]",
      "properties": {
        "basePolicyName": "Microsoft.Default",
        "mode": "Blocking",
        "contentFilters": [
          {
            "name": "Hate",
            "severityThreshold": "High",
            "source": "Prompt",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "Hate",
            "severityThreshold": "High",
            "source": "Completion",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "Sexual",
            "severityThreshold": "High",
            "source": "Prompt",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "Sexual",
            "severityThreshold": "High",
            "source": "Completion",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "Violence",
            "severityThreshold": "High",
            "source": "Prompt",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "Violence",
            "severityThreshold": "High",
            "source": "Completion",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "SelfHarm",
            "severityThreshold": "High",
            "source": "Prompt",
            "enabled": true,
            "blocking": true
          },
          {
            "name": "SelfHarm",
            "severityThreshold": "High",
            "source": "Completion",
            "enabled": true,
            "blocking": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName'))]"
      ]
    },
    {
      "condition": "[parameters('deployAiFoundry')]",
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('generatedAiFoundryName'), parameters('aiDeploymentName'))]",
      "sku": {
        "name": "[parameters('aiDeploymentSkuName')]",
        "capacity": "[parameters('aiDeploymentCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('aiModelName')]",
          "version": "[parameters('aiModelVersion')]"
        },
        "raiPolicyName": "[if(empty(parameters('raiPolicyName')), null(), parameters('raiPolicyName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('generatedWebAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('generatedAppServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "linuxFxVersion": "NODE|20-lts",
          "appSettings": [
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "NODE_ENV",
              "value": "production"
            },
            {
              "name": "PORT",
              "value": "8080"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "false"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[if(parameters('deployAiFoundry'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName')), '2024-10-01').endpoint, parameters('existingAiFoundryEndpoint'))]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('aiDeploymentName')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAiApiVersion')]"
            }
          ]
        }
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "AI Chat Application",
        "TargetAudience": "Students Under 16",
        "ManagedBy": "Bicep"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName'))]",
        "[resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('generatedAppServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[variables('generatedSqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[variables('sqlPassword')]",
        "version": "12.0",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "SQL Server",
        "ManagedBy": "Bicep"
      }
    },
    {
      "condition": "[and(not(empty(parameters('sqlAzureAdAdminLogin'))), not(empty(parameters('sqlAzureAdAdminObjectId'))))]",
      "type": "Microsoft.Sql/servers/administrators",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('generatedSqlServerName'), 'ActiveDirectory')]",
      "properties": {
        "administratorType": "ActiveDirectory",
        "login": "[parameters('sqlAzureAdAdminLogin')]",
        "sid": "[parameters('sqlAzureAdAdminObjectId')]",
        "tenantId": "[parameters('azureTenantId')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('generatedSqlServerName'), parameters('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sqlSkuName')]"
      },
      "properties": {
        "maxSizeBytes": 2147483648
      },
      "tags": {
        "Environment": "[parameters('environment')]",
        "School": "[parameters('schoolName')]",
        "Project": "SchoolGPT",
        "Purpose": "Application Database",
        "ManagedBy": "Bicep"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('generatedSqlServerName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', variables('generatedWebAppName'), 'appsettings')]",
      "properties": {
        "SCM_DO_BUILD_DURING_DEPLOYMENT": "true",
        "NODE_ENV": "production",
        "PORT": "8080",
        "WEBSITES_ENABLE_APP_SERVICE_STORAGE": "false",
        "APPINSIGHTS_INSTRUMENTATIONKEY": "[reference(resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName')), '2020-02-02').InstrumentationKey]",
        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName')), '2020-02-02').ConnectionString]",
        "SQL_CONNECTION_STRING": "[format('Server=tcp:{0},1433;Initial Catalog={1};Persist Security Info=False;User ID={2};Password={3};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;', reference(resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName, parameters('sqlDatabaseName'), parameters('sqlAdminLogin'), variables('sqlPassword'))]",
        "AZURE_OPENAI_ENDPOINT": "[if(parameters('deployAiFoundry'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName')), '2024-10-01').endpoint, parameters('existingAiFoundryEndpoint'))]",
        "AZURE_OPENAI_DEPLOYMENT": "[parameters('aiDeploymentName')]",
        "AZURE_OPENAI_API_VERSION": "[parameters('azureOpenAiApiVersion')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName'))]",
        "[resourceId('Microsoft.Insights/components', variables('generatedAppInsightsName'))]",
        "[resourceId('Microsoft.Sql/servers/databases', variables('generatedSqlServerName'), parameters('sqlDatabaseName'))]",
        "[resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName'))]",
        "[resourceId('Microsoft.Web/sites', variables('generatedWebAppName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('generatedKeyVaultName'), 'sql-connection-string')]",
      "properties": {
        "value": "[format('Server=tcp:{0},1433;Initial Catalog={1};Persist Security Info=False;User ID={2};Password={3};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;', reference(resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName, parameters('sqlDatabaseName'), parameters('sqlAdminLogin'), variables('sqlPassword'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('generatedKeyVaultName'))]",
        "[resourceId('Microsoft.Sql/servers', variables('generatedSqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('generatedKeyVaultName'), 'sql-admin-password')]",
      "properties": {
        "value": "[variables('sqlPassword')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('generatedKeyVaultName'))]"
      ]
    },
    {
      "condition": "[and(and(parameters('deployAiFoundry'), parameters('autoGrantAiAccess')), not(empty(variables('effectiveAiFoundryName'))))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName'))]",
      "name": "[guid(resourceGroup().id, resourceId('Microsoft.Web/sites', variables('generatedWebAppName')), variables('effectiveAiFoundryName'), 'openai-user')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('generatedWebAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('generatedWebAppName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('generatedWebAppName')]"
    },
    "frontendUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('generatedWebAppName')), '2023-12-01').defaultHostName)]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('generatedKeyVaultName')]"
    },
    "sqlServerName": {
      "type": "string",
      "value": "[variables('generatedSqlServerName')]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[parameters('sqlDatabaseName')]"
    },
    "azureOpenAiEndpoint": {
      "type": "string",
      "value": "[if(parameters('deployAiFoundry'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('generatedAiFoundryName')), '2024-10-01').endpoint, parameters('existingAiFoundryEndpoint'))]"
    },
    "azureOpenAiDeployment": {
      "type": "string",
      "value": "[parameters('aiDeploymentName')]"
    },
    "webAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('generatedWebAppName')), '2023-12-01', 'full').identity.principalId]"
    }
  }
}
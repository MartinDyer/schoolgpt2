#################################################################
# SchoolGPT Application Environment Variables Template
# Copy this to .env and update with your values from Terraform outputs
#################################################################

# =============================================================================
# AZURE AI FOUNDRY CONFIGURATION
# =============================================================================

# AI Foundry Endpoint (from Terraform output: ai_foundry_endpoint)
AI_FOUNDRY_ENDPOINT=https://your-ai-foundry.openai.azure.com/

# AI Foundry API Key (from Terraform output: ai_foundry_api_key)
AI_FOUNDRY_KEY=your-ai-foundry-api-key

# Model Configuration
AI_FOUNDRY_MODEL=gpt-35-turbo
AI_FOUNDRY_MODEL_VERSION=1106
AI_FOUNDRY_TEMPERATURE=0.1
AI_FOUNDRY_MAX_TOKENS=1000
AI_FOUNDRY_STREAM=true

# System Message for School-Safe AI
AI_FOUNDRY_SYSTEM_MESSAGE=You are a helpful AI assistant for students. Always provide educational, age-appropriate responses. Avoid any content that could be harmful or inappropriate for students under 16.

# =============================================================================
# TABLE STORAGE CONFIGURATION (RECOMMENDED)
# =============================================================================

# Table Storage Connection String (from Terraform output: table_storage_connection_string)
TABLE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorage;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Table Names
TABLE_STORAGE_CONVERSATIONS_TABLE=conversations
TABLE_STORAGE_MESSAGES_TABLE=messages
TABLE_STORAGE_ENABLE_FEEDBACK=false

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Authentication
AUTH_ENABLED=true

# UI Customization
UI_TITLE=SchoolGPT AI Assistant
UI_CHAT_TITLE=Start chatting with your AI assistant
UI_CHAT_DESCRIPTION=This AI assistant is configured to help you with educational questions
UI_SHOW_SHARE_BUTTON=true
UI_SHOW_CHAT_HISTORY_BUTTON=true

# Content Filtering
SANITIZE_ANSWER=true

# =============================================================================
# MONITORING & SECURITY
# =============================================================================

# Microsoft Defender for Cloud (if enabled)
MS_DEFENDER_ENABLED=true

# Debug Mode (set to false in production)
DEBUG=false

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# 1. Get connection strings from Terraform outputs:
#    terraform output table_storage_connection_string
#    terraform output ai_foundry_api_key
#
# 2. Update this file with your actual values
#
# 3. For production, use Azure Key Vault to store sensitive values
#
# 4. Table Storage is recommended for cost-effectiveness
#
# ============================================================================= 